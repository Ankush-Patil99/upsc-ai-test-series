# ─────────────────────────────────────────────────────────────────────────────
# UPSC AI Engine V2.0 — Environment Configuration
# Copy this file to .env and fill in your actual values
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string
PG_DSN=postgresql://your_user:your_password@localhost:5432/upscdb

# vLLM endpoints (set by start_vllm.sh)
VLLM_HEAVY_BASE_URL=http://localhost:8001/v1
VLLM_LIGHT_BASE_URL=http://localhost:8002/v1

# Model names (must match what vLLM is serving)
HEAVY_MODEL_NAME=Qwen/Qwen2.5-72B-Instruct-AWQ
LIGHT_MODEL_NAME=mistralai/Mistral-7B-Instruct-v0.3

# Embedding models
RAG_EMBED_MODEL=BAAI/bge-large-en-v1.5
DEDUP_EMBED_MODEL=BAAI/bge-small-en

# ChromaDB
CHROMA_PERSIST_DIR=./pipeline_data/chroma_db
CHROMA_COLLECTION=upsc_questions
CHROMA_RAG_COLLECTION=upsc_knowledge
DEDUP_THRESHOLD=0.85

# Static knowledge base directory
KB_BASE_DIR=./static_kb

# LangGraph checkpointing
CHECKPOINT_DB_PATH=./checkpoints/pipeline.db

# QA thresholds
QA_PASS_THRESHOLD=0.75
MAX_RETRIES=3

# Output directory
OUTPUT_DIR=./output

# Generation parameters
HEAVY_MAX_TOKENS=2048
LIGHT_MAX_TOKENS=1024
TEMPERATURE=0.7
PGV_TOP_K_CA=5
PGV_TOP_K_TEXTBOOK=3

# ── Current Affairs Scraper (ca_scraper.py) ─────────────────────────────────
# How often the APScheduler daemon re-scrapes all 7 sources (in hours)
CA_SCRAPE_INTERVAL_HOURS=24

# HTTP timeout (seconds) and retry count for web requests
CA_REQUEST_TIMEOUT=30
CA_MAX_RETRIES=3

# Chunk sizing for scraped CA articles
CA_CHUNK_SIZE=600
CA_CHUNK_OVERLAP=80
CA_MIN_CHUNK_CHARS=100

# Number of articles to ingest per run from RSS and HTML sources
CA_RSS_ARTICLE_LIMIT=3
CA_HTML_ARTICLE_LIMIT=5

# Source URLs (override only if sources change their domains)
VISIONIAS_PDF_URL=https://www.visionias.in/resources/current-affairs/monthly/
INSIGHTSIAS_PDF_URL=https://www.insightsonindia.com/wp-content/uploads/
FORUMIAS_BASE_URL=https://forumias.com/blog/9pm/
HINDU_RSS_URL=https://www.thehindu.com/opinion/editorial/feeder/default.rss
IE_RSS_URL=https://indianexpress.com/section/explained/feed/
PIB_URL=https://pib.gov.in/allRel.aspx
DRISHTI_ENV_URL=https://www.drishtiias.com/tags/biodiversity-&-environment
